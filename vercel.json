{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "cd web && npm install && npm run build",
  "outputDirectory": "web/dist",
  "functions": {
    "api/index.py": { "memory": 1024, "maxDuration": 30 }
  },
  "routes": [
    { "src": "/api(/.*)?", "dest": "/api/index" },
    {
      "src": "/assets/(.*)",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/v1/internal/cron/refresh-us-daily",
      "schedule": "30 22 * * 1-5"
    },
    {
      "path": "/api/v1/internal/cron/refresh-kr-daily",
      "schedule": "0 10 * * 1-5"
    },
    {
      "path": "/api/v1/internal/cron/ingest-finnhub",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/v1/internal/cron/ingest-13f",
      "schedule": "0 6 * * 1"
    }
  ]
}
