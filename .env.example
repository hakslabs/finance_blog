# Root .env shared by web/ and api/. Copy to .env (gitignored).
# Authoritative matrix and ownership: docs/ENV.md.
# Provider choices: docs/design-docs/data-sources.md.
# Anything prefixed VITE_ is shipped to the browser bundle — never put a secret there.

# ============================================================
# App config
# ============================================================
APP_ENV=local              # local | preview | prod. Controls dev-header acceptance.
LOG_LEVEL=info             # debug | info | warn | error
VITE_API_BASE_URL=http://localhost:8000

# ============================================================
# Supabase
# ============================================================
# Backend
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=
# Browser (anon key is public-safe)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ============================================================
# Auth — PR-14 (final PR)
# ============================================================
SUPABASE_JWT_SECRET=
# Dev-only user identity until PR-14 lands. Seeded by PR-08.
# Production builds (APP_ENV != local) must leave this empty.
VITE_DEV_USER_ID=00000000-0000-4000-8000-000000000001

# ============================================================
# Vercel deployment — PR-12
# ============================================================
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# ============================================================
# Backend hosting deployment — PR-12 (choose one when picked)
# ============================================================
# RENDER_API_KEY=
# FLY_API_TOKEN=

# ============================================================
# Market data providers
# ============================================================
# US daily OHLCV — primary (S&P500 + Nasdaq100)
POLYGON_API_KEY=
# US daily OHLCV — fallback (per-symbol top-ups when Polygon is down)
ALPHA_VANTAGE_API_KEY=
# KR daily OHLCV — primary (KOSPI200), official KRX OpenAPI
KRX_API_KEY=
# US filings (SEC requires a contact email in User-Agent)
SEC_USER_AGENT=
# KR filings / financials
DART_API_KEY=
# KR market data via KIS — deferred per data-sources.md
# KIS_APP_KEY=
# KIS_APP_SECRET=

# ============================================================
# Macro providers
# ============================================================
FRED_API_KEY=
ECOS_API_KEY=

# ============================================================
# Observability — deferred
# ============================================================
# SENTRY_DSN_API=
# VITE_SENTRY_DSN_WEB=
